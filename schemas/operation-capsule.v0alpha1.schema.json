{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kubeactuary.dev/schemas/operation-capsule.v0alpha1.schema.json",
  "title": "KubeActuary OperationCapsule",
  "type": "object",
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec",
    "status"
  ],
  "properties": {
    "apiVersion": {
      "const": "kubeactuary.dev/v0alpha1"
    },
    "kind": {
      "const": "OperationCapsule"
    },
    "metadata": {
      "type": "object",
      "required": [
        "id",
        "createdAt"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^opcap-[a-zA-Z0-9._-]+$"
        },
        "createdAt": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "spec": {
      "type": "object",
      "required": [
        "intent",
        "actor",
        "target",
        "risk",
        "requiredEvidence",
        "rollback",
        "postChecks"
      ],
      "properties": {
        "intent": {
          "type": "string",
          "minLength": 1
        },
        "actor": {
          "type": "string",
          "minLength": 1
        },
        "kubeContext": {
          "type": [
            "string",
            "null"
          ]
        },
        "proposedCommand": {
          "type": [
            "string",
            "null"
          ]
        },
        "manifestPath": {
          "type": [
            "string",
            "null"
          ]
        },
        "target": {
          "type": "object",
          "required": [
            "verb",
            "scope",
            "modifiesCluster"
          ],
          "properties": {
            "raw": {
              "type": [
                "string",
                "null"
              ]
            },
            "verb": {
              "type": "string"
            },
            "resource": {
              "type": [
                "string",
                "null"
              ]
            },
            "name": {
              "type": [
                "string",
                "null"
              ]
            },
            "namespace": {
              "type": [
                "string",
                "null"
              ]
            },
            "scope": {
              "enum": [
                "namespace",
                "cluster",
                "unknown"
              ]
            },
            "modifiesCluster": {
              "type": "boolean"
            }
          },
          "additionalProperties": true
        },
        "risk": {
          "type": "object",
          "required": [
            "level",
            "reasons"
          ],
          "properties": {
            "level": {
              "enum": [
                "low",
                "medium",
                "high",
                "critical"
              ]
            },
            "reasons": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        },
        "requiredEvidence": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "description"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "description": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "rollback": {
          "type": "object",
          "required": [
            "required",
            "provided"
          ],
          "properties": {
            "required": {
              "type": "boolean"
            },
            "provided": {
              "type": "boolean"
            },
            "notes": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "postChecks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "status": {
      "type": "object",
      "required": [
        "state",
        "evidence"
      ],
      "properties": {
        "state": {
          "enum": [
            "drafted",
            "evidence-attached",
            "verified",
            "blocked",
            "executed"
          ]
        },
        "evidence": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": [
              "ok",
              "summary",
              "actor",
              "attachedAt"
            ],
            "properties": {
              "ok": {
                "type": "boolean"
              },
              "summary": {
                "type": "string"
              },
              "actor": {
                "type": "string"
              },
              "attachedAt": {
                "type": "string"
              },
              "source": {
                "type": "string"
              },
              "sourceSha256": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        },
        "observations": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
