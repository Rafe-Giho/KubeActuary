#!/usr/bin/env python3
"""Dry-run entrypoint for the KubeActuary controller reconcile model."""

from __future__ import annotations

import argparse
import json
import shlex
import subprocess
import sys
import time
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from controller.reconcile import (
    WATCH_RESOURCE,
    list_command,
    reconcile_status,
    status_patch,
    status_patch_plan,
    watch_command,
)
from controller.runtime import (
    health_payload,
    leader_election_config,
    metrics_text,
    readiness_payload,
    resource_budget_payload,
    resource_measure_command,
)


def load_json(path: str) -> dict:
    try:
        if path == "-":
            return json.loads(sys.stdin.read())
        return json.loads(Path(path).read_text())
    except FileNotFoundError as exc:
        raise SystemExit(f"file not found: {path}") from exc
    except json.JSONDecodeError as exc:
        raise SystemExit(f"invalid JSON in {path}: {exc}") from exc


def write_json(document: dict) -> None:
    print(json.dumps(document, indent=2, sort_keys=True))


def reconcile(args: argparse.Namespace) -> int:
    document = load_json(args.file)
    if args.format == "patch":
        write_json(status_patch(document))
    else:
        write_json(reconcile_status(document))
    return 0


def print_watch_command(args: argparse.Namespace) -> int:
    print(shlex.join(watch_command(args.namespace)))
    return 0


def patch_plan(args: argparse.Namespace) -> int:
    document = load_json(args.file)
    plan = status_patch_plan(document, kubectl=args.kubectl)
    if args.format == "commands":
        for patch in plan["patches"]:
            print(shlex.join(patch["command"]))
    else:
        write_json(plan)
    return 0


def sync(args: argparse.Namespace) -> int:
    try:
        plan = sync_plan(args.namespace, args.kubectl)
    except RuntimeError as exc:
        print(str(exc), file=sys.stderr)
        return 1
    if args.format == "commands":
        for patch in plan["patches"]:
            print(shlex.join(patch["command"]))
    else:
        write_json(plan)
    return 0


def sync_plan(namespace: str | None, kubectl: str) -> dict:
    command = list_command(namespace, kubectl=kubectl)
    result = subprocess.run(
        command,
        cwd=ROOT,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        check=False,
    )
    if result.returncode != 0:
        message = result.stderr.strip() or f"kubectl get failed with exit code {result.returncode}"
        raise RuntimeError(message)
    try:
        document = json.loads(result.stdout)
    except json.JSONDecodeError as exc:
        raise RuntimeError(f"invalid JSON from kubectl get: {exc}") from exc

    plan = status_patch_plan(document, kubectl=kubectl)
    plan["readExecution"] = "kubectl-get"
    plan["readCommand"] = command
    return plan


def run_patch_plan(plan: dict, execute: bool) -> dict:
    results = []
    failed = 0
    for patch in plan["patches"]:
        command = list(patch["command"])
        if not execute:
            command.append("--dry-run=server")
        result = subprocess.run(
            command,
            cwd=ROOT,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            check=False,
        )
        ok = result.returncode == 0
        if not ok:
            failed += 1
        results.append(
            {
                "name": patch["name"],
                "namespace": patch["namespace"],
                "command": command,
                "exitCode": result.returncode,
                "ok": ok,
                "stdout": result.stdout,
                "stderr": result.stderr,
            }
        )
    return {
        "mode": "status-patch" if execute else "server-dry-run",
        "writeExecution": "enabled-status-only" if execute else "disabled",
        "patchScope": "status",
        "count": len(results),
        "failed": failed,
        "results": results,
    }


def apply_status(args: argparse.Namespace) -> int:
    document = load_json(args.file)
    plan = status_patch_plan(document, kubectl=args.kubectl)
    report = run_patch_plan(plan, execute=args.execute)
    write_json(report)
    return 1 if report["failed"] else 0


def controller_loop(args: argparse.Namespace) -> int:
    if args.iterations < 0:
        print("--iterations must be >= 0", file=sys.stderr)
        return 2
    if args.interval_seconds < 0:
        print("--interval-seconds must be >= 0", file=sys.stderr)
        return 2
    if args.iterations == 0 and args.format == "json":
        print("--iterations 0 requires --format ndjson", file=sys.stderr)
        return 2

    failed = 0
    ticks = []
    iteration = 0
    try:
        while args.iterations == 0 or iteration < args.iterations:
            iteration += 1
            plan = sync_plan(args.namespace, args.kubectl)
            patch_report = run_patch_plan(plan, execute=args.execute)
            failed += patch_report["failed"]
            tick = {
                "iteration": iteration,
                "readExecution": plan["readExecution"],
                "readCommand": plan["readCommand"],
                "mode": patch_report["mode"],
                "writeExecution": patch_report["writeExecution"],
                "patchScope": patch_report["patchScope"],
                "count": patch_report["count"],
                "failed": patch_report["failed"],
                "results": patch_report["results"],
            }
            if args.format == "ndjson":
                print(json.dumps(tick, sort_keys=True), flush=True)
            else:
                ticks.append(tick)
            if args.iterations != 0 and iteration >= args.iterations:
                break
            time.sleep(args.interval_seconds)
    except RuntimeError as exc:
        print(str(exc), file=sys.stderr)
        return 1

    if args.format == "json":
        write_json(
            {
                "mode": "status-patch-loop" if args.execute else "server-dry-run-loop",
                "writeExecution": "enabled-status-only" if args.execute else "disabled",
                "readExecution": "kubectl-get",
                "patchScope": "status",
                "iterations": len(ticks),
                "intervalSeconds": args.interval_seconds,
                "failed": failed,
                "ticks": ticks,
            }
        )
    return 1 if failed else 0


def health(args: argparse.Namespace) -> int:
    write_json(health_payload(started_at=args.started_at, now=args.now))
    return 0


def ready(args: argparse.Namespace) -> int:
    write_json(readiness_payload(rbac_mode=args.rbac_mode, leader_election=args.leader_election))
    return 0


def metrics(args: argparse.Namespace) -> int:
    print(
        metrics_text(
            reconcile_total=args.reconcile_total,
            reconcile_errors_total=args.reconcile_errors_total,
            gate_open_total=args.gate_open_total,
        ),
        end="",
    )
    return 0


def leader_election(args: argparse.Namespace) -> int:
    write_json(
        leader_election_config(
            namespace=args.namespace,
            lease_name=args.lease_name,
            identity=args.identity,
        )
    )
    return 0


def resource_budget(args: argparse.Namespace) -> int:
    write_json(resource_budget_payload())
    return 0


def measure_command(args: argparse.Namespace) -> int:
    print(shlex.join(resource_measure_command(args.namespace)))
    return 0


def serve(args: argparse.Namespace) -> int:
    config = {
        "host": args.host,
        "port": args.port,
        "paths": ["/healthz", "/readyz", "/metrics"],
        "watchResource": WATCH_RESOURCE,
        "clusterAccess": "none",
    }
    if args.print_config:
        write_json(config)
        return 0

    started_at = int(time.time())

    class Handler(BaseHTTPRequestHandler):
        def send_text(self, status: int, content_type: str, body: str) -> None:
            encoded = body.encode("utf-8")
            self.send_response(status)
            self.send_header("Content-Type", content_type)
            self.send_header("Content-Length", str(len(encoded)))
            self.end_headers()
            self.wfile.write(encoded)

        def do_GET(self) -> None:
            if self.path == "/healthz":
                body = json.dumps(health_payload(started_at=started_at), sort_keys=True)
                self.send_text(200, "application/json", body + "\n")
            elif self.path == "/readyz":
                body = json.dumps(readiness_payload(rbac_mode=args.rbac_mode), sort_keys=True)
                self.send_text(200, "application/json", body + "\n")
            elif self.path == "/metrics":
                self.send_text(200, "text/plain; version=0.0.4", metrics_text())
            else:
                self.send_text(404, "text/plain", "not found\n")

        def log_message(self, _format: str, *_args: object) -> None:
            return

    server = ThreadingHTTPServer((args.host, args.port), Handler)
    print(f"kube-actuary-controller serve http://{args.host}:{args.port}", flush=True)
    server.serve_forever()
    return 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        description="Dry-run KubeActuary controller reconcile helpers.",
    )
    sub = parser.add_subparsers(dest="command_name", required=True)

    reconcile_parser = sub.add_parser("reconcile", help="compute status for one OperationCapsule JSON object")
    reconcile_parser.add_argument("file")
    reconcile_parser.add_argument("--format", choices=["status", "patch"], default="status")
    reconcile_parser.set_defaults(func=reconcile)

    watch_parser = sub.add_parser("watch-command", help="print the only Kubernetes watch command this controller needs")
    watch_parser.add_argument("--namespace")
    watch_parser.set_defaults(func=print_watch_command)

    patch_plan_parser = sub.add_parser("patch-plan", help="compute status patch commands without executing them")
    patch_plan_parser.add_argument("file", help="OperationCapsule JSON object/list file, or - for stdin")
    patch_plan_parser.add_argument("--format", choices=["json", "commands"], default="json")
    patch_plan_parser.add_argument("--kubectl", default="kubectl")
    patch_plan_parser.set_defaults(func=patch_plan)

    sync_parser = sub.add_parser("sync", help="read OperationCapsules and compute status patch plans without writes")
    sync_parser.add_argument("--namespace", help="limit the read to one namespace")
    sync_parser.add_argument("--format", choices=["json", "commands"], default="json")
    sync_parser.add_argument("--kubectl", default="kubectl")
    sync_parser.set_defaults(func=sync)

    apply_status_parser = sub.add_parser("apply-status", help="run status patch server dry-run, or execute status-only writes explicitly")
    apply_status_parser.add_argument("file", help="OperationCapsule JSON object/list file, or - for stdin")
    apply_status_parser.add_argument("--kubectl", default="kubectl")
    apply_status_parser.add_argument("--execute", action="store_true", help="execute status subresource patches instead of server dry-run")
    apply_status_parser.set_defaults(func=apply_status)

    loop_parser = sub.add_parser("loop", help="repeat read/status-patch ticks; dry-run by default")
    loop_parser.add_argument("--namespace", help="limit the read to one namespace")
    loop_parser.add_argument("--kubectl", default="kubectl")
    loop_parser.add_argument("--iterations", type=int, default=1, help="number of ticks; 0 runs forever with --format ndjson")
    loop_parser.add_argument("--interval-seconds", type=float, default=30.0)
    loop_parser.add_argument("--format", choices=["json", "ndjson"], default="json")
    loop_parser.add_argument("--execute", action="store_true", help="execute status subresource patches instead of server dry-run")
    loop_parser.set_defaults(func=controller_loop)

    health_parser = sub.add_parser("health", help="emit liveness payload for future /healthz wiring")
    health_parser.add_argument("--started-at", type=int)
    health_parser.add_argument("--now", type=int)
    health_parser.set_defaults(func=health)

    ready_parser = sub.add_parser("ready", help="emit readiness payload for future /readyz wiring")
    ready_parser.add_argument("--rbac-mode", choices=["namespace", "cluster"], default="namespace")
    ready_parser.add_argument("--no-leader-election", dest="leader_election", action="store_false")
    ready_parser.set_defaults(func=ready, leader_election=True)

    metrics_parser = sub.add_parser("metrics", help="emit Prometheus text metrics for future /metrics wiring")
    metrics_parser.add_argument("--reconcile-total", type=int, default=0)
    metrics_parser.add_argument("--reconcile-errors-total", type=int, default=0)
    metrics_parser.add_argument("--gate-open-total", type=int, default=0)
    metrics_parser.set_defaults(func=metrics)

    election_parser = sub.add_parser("leader-election", help="emit Kubernetes Lease configuration")
    election_parser.add_argument("--namespace", default="kubeactuary-system")
    election_parser.add_argument("--lease-name", default="kubeactuary-controller")
    election_parser.add_argument("--identity")
    election_parser.set_defaults(func=leader_election)

    budget_parser = sub.add_parser("resource-budget", help="emit controller CPU and memory budget contract")
    budget_parser.set_defaults(func=resource_budget)

    measure_parser = sub.add_parser("measure-command", help="print kubectl top command for controller resource checks")
    measure_parser.add_argument("--namespace", default="kubeactuary-system")
    measure_parser.set_defaults(func=measure_command)

    serve_parser = sub.add_parser("serve", help="serve local controller health, readiness, and metrics endpoints")
    serve_parser.add_argument("--host", default="127.0.0.1")
    serve_parser.add_argument("--port", type=int, default=8080)
    serve_parser.add_argument("--rbac-mode", choices=["namespace", "cluster"], default="namespace")
    serve_parser.add_argument("--print-config", action="store_true", help="print server config and exit")
    serve_parser.set_defaults(func=serve)
    return parser


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
