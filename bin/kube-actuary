                "validate": {"0": "capsule structure is valid", "1": "capsule structure is invalid"},
                "doctor": {"0": "local checks passed or produced warnings", "1": "a required local check failed"},
                "gate": {"0": "gate is open", "1": "gate is closed"},
                "collect": {"0": "evidence was attached, even when the evidence itself is failed or inapplicable"},
            },
        },
    }


def command_line(command: dict[str, Any]) -> str:
    return f"  {command['name'] + ':':<22} {command['summary']}"


def format_bullets(lines: list[str]) -> list[str]:
    return [f"  {line}" for line in lines]


def command_group(names: set[str]) -> list[dict[str, Any]]:
    return [command for command in COMMAND_HELP if command["name"] in names]


def render_overview_help() -> str:
    core = command_group({"draft", "inspect", "validate", "doctor", "attach-evidence", "verify", "gate", "render-crd", "digest"})
    collectors = command_group({"collect auth", "collect dry-run", "collect diff", "collect rollback", "collect health-plan"})
    additional = command_group({"demo", "help"})
    lines = [
        "Evidence-carrying operations for AI-assisted Kubernetes.",
        "",
        "USAGE",
        "  kube-actuary <command> [flags]",
        "  kubectl actuary <command> [flags]",
        "",
        "CORE COMMANDS",
        *[command_line(command) for command in core],
        "",
        "COLLECTOR COMMANDS",
        *[command_line(command) for command in collectors],
        "",
        "ADDITIONAL COMMANDS",
        *[command_line(command) for command in additional],
        "",
        "HELP TOPICS",
        "  workflow:              End-to-end capsule flow",
        "  commands:              Full command reference",
        "  evidence:              Required evidence ids and meanings",
        "  safety:                What the CLI may and may not execute",
        "  agents:                Machine-readable usage contract",
        "  all:                   Full help bundle",
        "",
        "FLAGS",
        "  --help                 Show argparse help for a command",
        "  --version              Show kube-actuary version",
        "",
        "EXAMPLES",
        '  kube-actuary draft --intent "inspect pods" --command "kubectl get pods -n default"',
        "  kube-actuary collect auth capsule.json --out capsule.with-auth.json",
        "  kube-actuary gate capsule.with-evidence.json",
        "  kube-actuary help agents --format json",
        "",
        "SAFETY MODEL",
        "  The CLI collects evidence and opens/closes a gate. It does not execute proposed writes.",
        "",
        "LEARN MORE",
        "  Use `kube-actuary <command> --help` for command flags.",
        "  Use `kube-actuary help <topic>` for workflow, evidence, safety, or agent guidance.",
    ]
    return "\n".join(lines) + "\n"


def render_workflow_help() -> str:
    lines = [
        "WORKFLOW",
        *[f"  {index}. {step}" for index, step in enumerate(WORKFLOW_HELP, start=1)],
        "",
        "TYPICAL COMMAND PATH",
        "  draft -> inspect -> collect/attach evidence -> verify -> gate -> external execution path",
        "",
        "EXAMPLES",
        "  kube-actuary draft --intent \"apply demo config\" --manifest examples/configmap-demo.yaml --out capsule.json",
        "  kube-actuary collect auth capsule.json --out capsule.auth.json",
        "  kube-actuary collect dry-run capsule.auth.json --out capsule.dry-run.json",
        "  kube-actuary collect diff capsule.dry-run.json --out capsule.diff.json",
        "  kube-actuary collect rollback capsule.diff.json --manifest rollback.yaml --out capsule.rollback.json",
        "  kube-actuary collect health-plan capsule.rollback.json --out capsule.ready.json",
        "  kube-actuary gate capsule.ready.json",
    ]
    return "\n".join(lines) + "\n"


def render_commands_help() -> str:
    lines = ["COMMANDS"]
    lines.extend(command_line(command) for command in COMMAND_HELP)
    lines.extend(
        [
            "",
            "COMMAND DETAILS",
        ]
    )
    for command in COMMAND_HELP:
        lines.append(f"  {command['name']}")
        lines.append(f"    cluster access: {command['clusterAccess']}")
        lines.append(f"    cluster writes: {str(command['clusterWrites']).lower()}")
        lines.append(f"    capsule writes: {str(command['capsuleWrites']).lower()}")
        if command.get("evidence"):
            lines.append(f"    evidence: {', '.join(command['evidence'])}")
    return "\n".join(lines) + "\n"


def render_evidence_help() -> str:
    payload = help_payload("evidence")
    lines = [
        "EVIDENCE IDS",
        *[
            f"  {item['id'] + ':':<22} {item['description']} ({item['requiredFor']})"
            for item in payload["evidence"]
        ],
        "",
        "GATE RULE",
        "  gate opens only when every spec.requiredEvidence id is attached and ok=true.",
        "  failed required evidence blocks the gate.",
    ]
    return "\n".join(lines) + "\n"


def render_safety_help() -> str:
    lines = [
        "SAFETY MODEL",
        *format_bullets(SAFETY_HELP),
        "",
        "SAFE CLUSTER CALLS",
        "  kubectl version --client=true -o json",
        "  kubectl auth can-i ...",
        "  kubectl apply --dry-run=server -f <manifest>",
        "  kubectl diff -f <manifest>",
        "",
        "NEVER EXECUTED BY KUBEACTUARY",
        "  spec.proposedCommand",
        "  kubectl scale/delete/apply without server dry-run",
        "  interactive exec/attach/port-forward/proxy/debug",
    ]
    return "\n".join(lines) + "\n"


def render_agents_help() -> str:
    payload = help_payload("agents")
    contract = payload["agentContract"]
    lines = [
        "AGENT CONTRACT",
        f"  schema version: {payload['schemaVersion']}",
        f"  structured help: {contract['structuredHelp']}",
        f"  default output: {contract['defaultOutput']}",
        "",
        "RECOMMENDED AGENT FLOW",
        "  1. Run `kube-actuary help agents --format json` once and cache the contract.",
        "  2. Draft a capsule instead of executing kubectl writes.",
        "  3. Collect or attach required evidence.",
        "  4. Treat `gate` exit 0 as an execution candidate, not execution permission by itself.",
        "",
        "JSON CONTRACT FIELDS",
        "  commands[].clusterWrites says whether the command writes to the cluster.",
        "  commands[].clusterAccess says which cluster call, if any, the command may run.",
        "  compatibility.requiredCommandFields lists fields agents can rely on.",
        "  agentContract.neverExecutes lists operations the CLI refuses to run.",
        "  agentContract.exitCodes lists stable success/failure meanings.",
    ]
    return "\n".join(lines) + "\n"


def render_help_text(topic: str) -> str:
    if topic == "all":
        return "\n\n".join(
            [
                render_overview_help().rstrip(),
                render_workflow_help().rstrip(),
                render_commands_help().rstrip(),
                render_evidence_help().rstrip(),
                render_safety_help().rstrip(),
                render_agents_help().rstrip(),
            ]
        ) + "\n"
    renderers = {
        "overview": render_overview_help,
        "workflow": render_workflow_help,
        "commands": render_commands_help,
        "evidence": render_evidence_help,
        "safety": render_safety_help,
        "agents": render_agents_help,
    }
    return renderers[topic]()


def help_command(args: argparse.Namespace) -> int:
    if args.format == "json":
        write_json(help_payload(args.topic), "-")
        return 0
    write_text(render_help_text(args.topic), "-")
    return 0


def attach_evidence_record(
    capsule: dict[str, Any],
    evidence_id: str,
    evidence: dict[str, Any],
    allow_extra: bool = False,
) -> None:
    required_ids = {item["id"] for item in capsule.get("spec", {}).get("requiredEvidence", [])}
    if evidence_id not in required_ids and not allow_extra:
        raise SystemExit(f"unknown evidence id: {evidence_id}")

    status = capsule.setdefault("status", {})
    status.setdefault("evidence", {})[evidence_id] = evidence
    status.setdefault("observations", []).append(
        {
            "at": evidence["attachedAt"],
            "actor": evidence["actor"],
            "message": f"attached evidence {evidence_id}",
        }
    )
    update_state_from_evidence(capsule)


def write_capsule_result(capsule: dict[str, Any], file_path: str, output: str, in_place: bool) -> None:
    write_json(capsule, file_path if in_place else output)


def yaml_scalar(value: Any) -> str:
    if value is None:
        return "null"
    if isinstance(value, bool):
        return "true" if value else "false"
    if isinstance(value, (int, float)):
        return str(value)
    return json.dumps(str(value), ensure_ascii=False)


def yaml_dump(value: Any, indent: int = 0) -> list[str]:
    prefix = " " * indent
    lines: list[str] = []
    if isinstance(value, dict):
        for key, item in value.items():
            if isinstance(item, (dict, list)):
                lines.append(f"{prefix}{key}:")
                lines.extend(yaml_dump(item, indent + 2))
            else:
                lines.append(f"{prefix}{key}: {yaml_scalar(item)}")
    elif isinstance(value, list):
        if not value:
            lines.append(f"{prefix}[]")
        for item in value:
            if isinstance(item, dict):
                lines.append(f"{prefix}-")
                lines.extend(yaml_dump(item, indent + 2))
            elif isinstance(item, list):
                lines.append(f"{prefix}-")
                lines.extend(yaml_dump(item, indent + 2))
            else:
                lines.append(f"{prefix}- {yaml_scalar(item)}")
    else:
        lines.append(f"{prefix}{yaml_scalar(value)}")
    return lines


def capsule_to_crd(capsule: dict[str, Any], args: argparse.Namespace) -> dict[str, Any]:
    metadata = capsule.get("metadata", {})
    spec = capsule.get("spec", {})
    target = spec.get("target", {})
    risk = spec.get("risk", {})
    evidence = capsule.get("status", {}).get("evidence", {})
    name = args.name or dns_label(metadata.get("id", "operation-capsule"))
    namespace = args.namespace or target.get("namespace") or "default"

    actor_name = spec.get("actor") or "unknown"
    proposed_action = {
        "verb": target.get("verb") or "unknown",
    }
    if spec.get("proposedCommand"):
        proposed_action["command"] = spec["proposedCommand"]
    if target.get("resource"):
        proposed_action["resource"] = target["resource"]
    if target.get("name"):
        proposed_action["name"] = target["name"]
    if target.get("namespace"):
        proposed_action["namespace"] = target["namespace"]
    if spec.get("manifestPath"):
        proposed_action["manifestRef"] = spec["manifestPath"]

    crd_spec: dict[str, Any] = {
        "intent": spec.get("intent", ""),
        "actor": {
            "type": args.actor_type,
            "name": actor_name,
        },
        "proposedAction": proposed_action,
        "risk": {
            "level": risk.get("level", "medium"),
            "reasons": risk.get("reasons", []),
        },
        "requiredEvidence": [item.get("id") for item in spec.get("requiredEvidence", []) if item.get("id")],
        "postChecks": spec.get("postChecks", []),
    }

    if evidence:
        crd_spec["evidence"] = [
            crd_evidence_record(evidence_id, record)
            for evidence_id, record in sorted(evidence.items())
        ]

    rollback = spec.get("rollback", {})
    crd_spec["rollback"] = {
        "required": bool(rollback.get("required")),
        "provided": bool(rollback.get("provided")),
    }
    rollback_command = args.rollback_command or rollback.get("command")
    if rollback_command:
        crd_spec["rollback"]["command"] = rollback_command
    if rollback.get("manifestPath"):
        crd_spec["rollback"]["manifestRef"] = rollback["manifestPath"]
    if rollback.get("manifestSha256"):
        crd_spec["rollback"]["manifestSha256"] = rollback["manifestSha256"]
    if args.ttl_seconds_after_finished is not None:
        crd_spec["ttlSecondsAfterFinished"] = args.ttl_seconds_after_finished

    return {
        "apiVersion": "ops.kubeactuary.dev/v1alpha1",
        "kind": "OperationCapsule",
        "metadata": {
            "name": name,
            "namespace": namespace,
            "labels": {
                "kubeactuary.dev/source": "local-capsule",
            },
            "annotations": {
                "kubeactuary.dev/capsule-id": metadata.get("id", ""),
                "kubeactuary.dev/capsule-digest": f"sha256:{capsule_spec_digest(capsule)}",
            },
        },
        "spec": crd_spec,
        "status": capsule_crd_status(capsule),
    }


def crd_evidence_record(evidence_id: str, record: dict[str, Any]) -> dict[str, Any]:
    rendered = {
        "id": evidence_id,
        "ok": bool(record.get("ok")),
        "summary": record.get("summary", ""),
        "actor": record.get("actor", ""),
        "attachedAt": record.get("attachedAt", ""),
    }
    if record.get("source"):
        rendered["sourceRef"] = record["source"]
    if record.get("sourceSha256"):
        rendered["sourceSha256"] = record["sourceSha256"]
    for field in ("collector", "exitCode", "inapplicable", "diffFound", "rollbackType", "reason"):
        if field in record:
            rendered[field] = record[field]
    return rendered


def crd_condition(condition_type: str, status: bool, reason: str, message: str) -> dict[str, Any]:
    return {
        "type": condition_type,
        "status": "True" if status else "False",
        "reason": reason,
        "message": message,
    }


def capsule_crd_status(capsule: dict[str, Any]) -> dict[str, Any]:
    missing, failed = evidence_gaps(capsule)
    spec = capsule.get("spec", {})
    rollback = spec.get("rollback", {})
    digest = f"sha256:{capsule_spec_digest(capsule)}"
    evidence_complete = not missing and not failed
    blocked = bool(failed)
    gate_open = evidence_complete and not blocked
    rollback_required = bool(rollback.get("required"))
    rollback_ready = (not rollback_required) or bool(rollback.get("provided"))
    expired = False

    if gate_open:
        phase = "GateOpen"
    elif blocked:
        phase = "Blocked"
    elif missing:
        phase = "EvidenceAttached"
    else:
        phase = "Drafted"

    conditions = [
        crd_condition(
            "EvidenceComplete",
            evidence_complete,
            "AllEvidencePresent" if evidence_complete else "EvidenceMissingOrFailed",
            "all required evidence is present and successful"
            if evidence_complete
            else "required evidence is missing or failed",
        ),
        crd_condition(
            "GateOpen",
            gate_open,
            "GateOpen" if gate_open else "GateClosed",
            "capsule is an execution candidate" if gate_open else "capsule is not an execution candidate",
        ),
        crd_condition(
            "Blocked",
            blocked,
            "FailedEvidencePresent" if blocked else "NoFailedEvidence",
            "one or more required evidence records failed" if blocked else "no failed required evidence",
        ),
        crd_condition(
            "RollbackReady",
            rollback_ready,
            "RollbackProvided" if rollback_ready else "RollbackMissing",
            "rollback evidence is available or not required"
            if rollback_ready
            else "rollback evidence is required but missing",
        ),
        crd_condition(
            "Expired",
            expired,
            "NotExpired",
            "no expiry policy has elapsed",
        ),
    ]

    return {
        "phase": phase,
        "gate": "Open" if gate_open else "Closed",
        "missingEvidence": missing,
        "failedEvidence": failed,
        "digest": digest,
        "conditions": conditions,
    }


def add_validation_error(errors: list[dict[str, str]], path: str, message: str) -> None:
    errors.append({"path": path, "message": message})


def object_at(errors: list[dict[str, str]], value: Any, path: str) -> dict[str, Any] | None:
    if isinstance(value, dict):
        return value
    add_validation_error(errors, path, "must be an object")
    return None


def list_at(errors: list[dict[str, str]], value: Any, path: str) -> list[Any] | None:
    if isinstance(value, list):
        return value
    add_validation_error(errors, path, "must be a list")
    return None


def require_key(errors: list[dict[str, str]], document: dict[str, Any], key: str, path: str) -> Any:
    if key not in document:
        add_validation_error(errors, f"{path}.{key}" if path else key, "is required")
        return None
    return document[key]


def require_string(
    errors: list[dict[str, str]],
    value: Any,
    path: str,
    *,
    non_empty: bool = False,
) -> None:
    if not isinstance(value, str):
        add_validation_error(errors, path, "must be a string")
        return
    if non_empty and not value.strip():
        add_validation_error(errors, path, "must not be empty")


def require_optional_string(errors: list[dict[str, str]], value: Any, path: str) -> None:
    if value is not None and not isinstance(value, str):
        add_validation_error(errors, path, "must be null or a string")


def require_bool(errors: list[dict[str, str]], value: Any, path: str) -> None:
    if not isinstance(value, bool):
        add_validation_error(errors, path, "must be a boolean")


def require_string_enum(errors: list[dict[str, str]], value: Any, path: str, allowed: set[str]) -> None:
    require_string(errors, value, path, non_empty=True)
    if isinstance(value, str) and value not in allowed:
        add_validation_error(errors, path, f"must be one of {', '.join(sorted(allowed))}")


def validate_string_list(errors: list[dict[str, str]], value: Any, path: str) -> None:
    items = list_at(errors, value, path)
    if items is None:
        return
    for index, item in enumerate(items):
        require_string(errors, item, f"{path}[{index}]", non_empty=True)


def validate_required_evidence(errors: list[dict[str, str]], value: Any) -> None:
    items = list_at(errors, value, "spec.requiredEvidence")
    if items is None:
        return

    seen: set[str] = set()
    for index, item in enumerate(items):
        path = f"spec.requiredEvidence[{index}]"
        record = object_at(errors, item, path)
        if record is None:
            continue
        evidence_id = require_key(errors, record, "id", path)
        require_string(errors, evidence_id, f"{path}.id", non_empty=True)
        if isinstance(evidence_id, str):
            if evidence_id in seen:
                add_validation_error(errors, f"{path}.id", "must be unique")
            seen.add(evidence_id)
        description = require_key(errors, record, "description", path)
        require_string(errors, description, f"{path}.description", non_empty=True)


def validate_evidence_records(errors: list[dict[str, str]], value: Any) -> None:
    records = object_at(errors, value, "status.evidence")
    if records is None:
        return
    for evidence_id, item in records.items():
        path = f"status.evidence.{evidence_id}"
        record = object_at(errors, item, path)
        if record is None:
            continue
        require_bool(errors, require_key(errors, record, "ok", path), f"{path}.ok")
        require_string(errors, require_key(errors, record, "summary", path), f"{path}.summary", non_empty=True)
        require_string(errors, require_key(errors, record, "actor", path), f"{path}.actor", non_empty=True)
        require_string(errors, require_key(errors, record, "attachedAt", path), f"{path}.attachedAt", non_empty=True)


def validate_capsule_document(capsule: Any) -> list[dict[str, str]]:
    errors: list[dict[str, str]] = []
    document = object_at(errors, capsule, "$")
    if document is None:
        return errors

    require_string(errors, require_key(errors, document, "apiVersion", ""), "apiVersion", non_empty=True)
    if document.get("apiVersion") != "kubeactuary.dev/v0alpha1":
        add_validation_error(errors, "apiVersion", "must be kubeactuary.dev/v0alpha1")
    require_string(errors, require_key(errors, document, "kind", ""), "kind", non_empty=True)
    if document.get("kind") != "OperationCapsule":
        add_validation_error(errors, "kind", "must be OperationCapsule")

    metadata = object_at(errors, require_key(errors, document, "metadata", ""), "metadata")
    if metadata is not None:
        metadata_id = require_key(errors, metadata, "id", "metadata")
        require_string(errors, metadata_id, "metadata.id", non_empty=True)
        if isinstance(metadata_id, str) and not metadata_id.startswith("opcap-"):
            add_validation_error(errors, "metadata.id", "must start with opcap-")
        require_string(errors, require_key(errors, metadata, "createdAt", "metadata"), "metadata.createdAt", non_empty=True)

    spec = object_at(errors, require_key(errors, document, "spec", ""), "spec")
    if spec is not None:
        require_string(errors, require_key(errors, spec, "intent", "spec"), "spec.intent", non_empty=True)
        require_string(errors, require_key(errors, spec, "actor", "spec"), "spec.actor", non_empty=True)
        require_optional_string(errors, spec.get("kubeContext"), "spec.kubeContext")
        require_optional_string(errors, spec.get("proposedCommand"), "spec.proposedCommand")
        require_optional_string(errors, spec.get("manifestPath"), "spec.manifestPath")

        target = object_at(errors, require_key(errors, spec, "target", "spec"), "spec.target")
        if target is not None:
            require_string(errors, require_key(errors, target, "verb", "spec.target"), "spec.target.verb", non_empty=True)
            require_string_enum(
                errors,
                require_key(errors, target, "scope", "spec.target"),
                "spec.target.scope",
                VALID_TARGET_SCOPES,
            )
            require_bool(
                errors,
                require_key(errors, target, "modifiesCluster", "spec.target"),
                "spec.target.modifiesCluster",
            )

        risk = object_at(errors, require_key(errors, spec, "risk", "spec"), "spec.risk")
        if risk is not None:
            require_string_enum(
                errors,
                require_key(errors, risk, "level", "spec.risk"),
                "spec.risk.level",
                VALID_RISK_LEVELS,
            )
            validate_string_list(errors, require_key(errors, risk, "reasons", "spec.risk"), "spec.risk.reasons")

        validate_required_evidence(errors, require_key(errors, spec, "requiredEvidence", "spec"))

        rollback = object_at(errors, require_key(errors, spec, "rollback", "spec"), "spec.rollback")
        if rollback is not None:
            require_bool(errors, require_key(errors, rollback, "required", "spec.rollback"), "spec.rollback.required")
            require_bool(errors, require_key(errors, rollback, "provided", "spec.rollback"), "spec.rollback.provided")
            require_optional_string(errors, rollback.get("command"), "spec.rollback.command")
            require_optional_string(errors, rollback.get("manifestPath"), "spec.rollback.manifestPath")
            require_optional_string(errors, rollback.get("manifestSha256"), "spec.rollback.manifestSha256")

        validate_string_list(errors, require_key(errors, spec, "postChecks", "spec"), "spec.postChecks")

    status = object_at(errors, require_key(errors, document, "status", ""), "status")
    if status is not None:
        require_string_enum(errors, require_key(errors, status, "state", "status"), "status.state", VALID_STATES)
        validate_evidence_records(errors, require_key(errors, status, "evidence", "status"))
        if "observations" in status and not isinstance(status["observations"], list):
            add_validation_error(errors, "status.observations", "must be a list")

    return errors


def validate_capsule(args: argparse.Namespace) -> int:
    capsule = load_capsule(args.file)
    errors = validate_capsule_document(capsule)

    if args.format == "json":
        write_json({"ok": not errors, "file": args.file, "errors": errors}, "-")
        return 0 if not errors else 1

    if errors:
        print("validation: failed")
        for error in errors:
            print(f"validation-error: {error['path']}: {error['message']}")
        return 1

    print("validation: passed")
    return 0


def doctor_check(checks: list[dict[str, Any]], check_id: str, status: str, summary: str) -> None:
    checks.append({"id": check_id, "status": status, "summary": summary})


def doctor_summary(checks: list[dict[str, Any]]) -> str:
    statuses = {check["status"] for check in checks}
    if "fail" in statuses:
        return "failed"
    if "warn" in statuses:
        return "ok-with-warnings"
    return "ok"


def parse_kubernetes_version(value: str | None) -> tuple[int, int] | None:
    if not value:
        return None
    match = re.search(r"v?(\d+)\.(\d+)", value)
    if not match:
        return None
    return int(match.group(1)), int(match.group(2))


def kubectl_client_version(output: str) -> str | None:
    try:
        payload = json.loads(output)
    except json.JSONDecodeError:
        match = re.search(r"Client Version:\s*(v?\d+\.\d+\.\S+)", output)
        return match.group(1) if match else None

    client = payload.get("clientVersion")
    if isinstance(client, dict):
        version = client.get("gitVersion")
        return version if isinstance(version, str) else None
    if isinstance(client, str):
        return client
    return None


def collect_doctor_checks(args: argparse.Namespace) -> list[dict[str, Any]]:
    checks: list[dict[str, Any]] = []
    python_version = f"{sys.version_info.major}.{sys.version_info.minor}.{sys.version_info.micro}"
    if sys.version_info >= (3, 10):
        doctor_check(checks, "python", "ok", f"Python {python_version} supports the current CLI")
    else:
        doctor_check(checks, "python", "fail", f"Python {python_version} is too old; Python 3.10+ is required")

    doctor_check(checks, "runtime-dependencies", "ok", "no external Python packages are required")

    kubectl_path = shutil.which(args.kubectl)
    if not kubectl_path:
        doctor_check(
            checks,
            "kubectl",
            "warn",
            f"kubectl not found at {args.kubectl}; collectors requiring kubectl will not run",
        )
        if args.server_version:
            doctor_check(checks, "kubectl-skew", "warn", "server version was provided but kubectl client is unavailable")
        return checks

    doctor_check(checks, "kubectl", "ok", f"kubectl found at {kubectl_path}")
    command = [kubectl_path, "version", "--client=true", "-o", "json"]
    try:
        result = subprocess.run(command, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, timeout=5, check=False)
    except subprocess.TimeoutExpired:
        doctor_check(checks, "kubectl-client-version", "warn", "kubectl client version command timed out")
        return checks
    except OSError as exc:
        doctor_check(checks, "kubectl-client-version", "warn", f"kubectl client version command failed: {exc}")
        return checks

    combined = (result.stdout + "\n" + result.stderr).strip()
    if result.returncode != 0:
        first_line = combined.splitlines()[0] if combined else "no output"
        doctor_check(
            checks,
            "kubectl-client-version",
            "warn",
            f"kubectl client version command returned {result.returncode}: {first_line}",
        )
        return checks

    client_version = kubectl_client_version(result.stdout)
    if not client_version:
        doctor_check(checks, "kubectl-client-version", "warn", "kubectl client version output was not recognized")
        return checks

    doctor_check(checks, "kubectl-client-version", "ok", f"kubectl client version: {client_version}")
    if not args.server_version:
        doctor_check(checks, "kubectl-skew", "ok", "server version not provided; skew comparison skipped")
        return checks

    client_minor = parse_kubernetes_version(client_version)
    server_minor = parse_kubernetes_version(args.server_version)
    if not client_minor:
        doctor_check(checks, "kubectl-skew", "warn", f"could not parse kubectl client version {client_version}")
    elif not server_minor:
        doctor_check(checks, "kubectl-skew", "warn", f"could not parse server version {args.server_version}")
    elif client_minor[0] != server_minor[0] or abs(client_minor[1] - server_minor[1]) > 1:
        doctor_check(
            checks,
            "kubectl-skew",
            "warn",
            f"client {client_version} may be outside one minor of server {args.server_version}",
        )
    else:
        doctor_check(
            checks,
            "kubectl-skew",
            "ok",
            f"client {client_version} is within one minor of server {args.server_version}",
        )
    return checks


def doctor(args: argparse.Namespace) -> int:
    checks = collect_doctor_checks(args)
    summary = doctor_summary(checks)

    if args.format == "json":
        write_json({"ok": summary != "failed", "summary": summary, "checks": checks}, "-")
        return 0 if summary != "failed" else 1

    print(f"doctor: {summary}")
    for check in checks:
        prefix = {"ok": "check", "warn": "warning", "fail": "failure"}[check["status"]]
        print(f"{prefix}: {check['id']}: {check['summary']}")
    return 0 if summary != "failed" else 1


def inspect_capsule(args: argparse.Namespace) -> int:
    capsule = load_capsule(args.file)
    spec = capsule.get("spec", {})
    target = spec.get("target", {})
    risk = spec.get("risk", {})
    attached = capsule.get("status", {}).get("evidence", {})
    print(f"id: {capsule.get('metadata', {}).get('id', 'unknown')}")
    print(f"state: {capsule.get('status', {}).get('state', 'unknown')}")
    print(f"intent: {spec.get('intent', '')}")
    print(f"actor: {spec.get('actor', '')}")
    print(f"command: {spec.get('proposedCommand') or spec.get('manifestPath') or '-'}")
    print(
        "target: "
        f"verb={target.get('verb')} resource={target.get('resource')} "
        f"name={target.get('name')} namespace={target.get('namespace')} scope={target.get('scope')}"
    )
    print(f"risk: {risk.get('level', 'unknown')}")
    for reason in risk.get("reasons", []):
        print(f"risk-reason: {reason}")
    print("required-evidence:")
    for item in spec.get("requiredEvidence", []):
        evidence_id = item.get("id")
        state = "attached" if evidence_id in attached else "missing"
        if attached.get(evidence_id, {}).get("ok") is False:
            state = "failed"
        print(f"- {evidence_id} [{state}]: {item.get('description')}")
    return 0


def verify_capsule(args: argparse.Namespace) -> int:
    capsule = load_capsule(args.file)
    missing, failed = evidence_gaps(capsule)

    if missing or failed:
        print("verification: failed")
        for item in missing:
            print(f"missing-evidence: {item}")
        for item in failed:
            print(f"failed-evidence: {item}")
        return 1

    print("verification: passed")
    return 0


def attach_evidence(args: argparse.Namespace) -> int:
    capsule = load_capsule(args.file)
    evidence = {
        "ok": not args.fail,
        "summary": args.summary,
        "actor": args.actor,
        "attachedAt": utc_now(),
    }
    if args.source:
        evidence["source"] = args.source
        evidence["sourceSha256"] = sha256_file(args.source)

    attach_evidence_record(capsule, args.id, evidence, args.allow_extra)
    write_capsule_result(capsule, args.file, args.out, args.in_place)
    return 0


def collect_auth(args: argparse.Namespace) -> int:
    capsule = load_capsule(args.file)
    spec = capsule.get("spec", {})
    target = spec.get("target", {})
    resource = target.get("resource") or "resource"
    verb = target.get("verb") or "get"
    evidence_id = "write-auth" if target.get("modifiesCluster") else "read-auth"
    command = [args.kubectl, "auth", "can-i", verb, resource]

    context = spec.get("kubeContext")
    namespace = target.get("namespace")
    if context:
        command.extend(["--context", context])
    if namespace and target.get("scope") != "cluster":
        command.extend(["-n", namespace])

    result = subprocess.run(command, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, check=False)
    stdout = result.stdout.strip()
    stderr = result.stderr.strip()
    ok = result.returncode == 0 and stdout.lower().splitlines()[:1] == ["yes"]
    reason = "command-ok" if ok else "authorization-denied"
    summary = collector_summary(reason, f"{shell_join(command)} returned {result.returncode}")
    if stdout:
        summary += f" with stdout: {stdout.splitlines()[0]}"

    evidence = {
        "ok": ok,
        "summary": summary,
        "actor": args.actor,
        "attachedAt": utc_now(),
        "collector": "kubectl-auth-can-i",
        "reason": reason,
        "command": command,
        "exitCode": result.returncode,
        "stdout": stdout,
        "stderr": stderr,
    }

    attach_evidence_record(capsule, evidence_id, evidence)
    write_capsule_result(capsule, args.file, args.out, args.in_place)
    return 0


def collect_dry_run(args: argparse.Namespace) -> int:
    capsule = load_capsule(args.file)
    spec = capsule.get("spec", {})
    target = spec.get("target", {})
    manifest = manifest_path(capsule, args.manifest)
    collector = "kubectl-server-dry-run"

    if not manifest:
        evidence = inapplicable_manifest_evidence(
            args,
            collector,
            "server-side dry-run requires a manifest path; proposed imperative commands are not executed",
        )
        attach_collector_evidence(capsule, "server-dry-run", evidence)
        write_capsule_result(capsule, args.file, args.out, args.in_place)
        return 0

    if not Path(manifest).is_file():
        evidence = {
            "ok": False,
            "summary": collector_summary("missing-source", f"manifest file not found: {manifest}"),
            "actor": args.actor,
            "attachedAt": utc_now(),
            "collector": collector,
            "reason": "manifest-not-found",
            **source_fields(manifest),
        }
        attach_collector_evidence(capsule, "server-dry-run", evidence)
        write_capsule_result(capsule, args.file, args.out, args.in_place)
        return 0

    command = scoped_kubectl_command(
        [args.kubectl, "apply", "--dry-run=server", "-f", manifest],
        spec,
        target,
    )
    result = subprocess.run(command, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, check=False)
    stdout = result.stdout.strip()
    stderr = result.stderr.strip()
    reason = "command-ok" if result.returncode == 0 else "command-failed"
    summary = collector_summary(reason, f"{shell_join(command)} returned {result.returncode}")
    if stdout:
        summary += f" with stdout: {stdout.splitlines()[0]}"

    evidence = {
        "ok": result.returncode == 0,
        "summary": summary,
        "actor": args.actor,
        "attachedAt": utc_now(),
        "collector": collector,
        "reason": reason,
        "command": command,
        "exitCode": result.returncode,
        "stdout": stdout,
        "stderr": stderr,
        **source_fields(manifest),
    }
    attach_collector_evidence(capsule, "server-dry-run", evidence)
    write_capsule_result(capsule, args.file, args.out, args.in_place)
    return 0


def collect_diff(args: argparse.Namespace) -> int:
    capsule = load_capsule(args.file)
    spec = capsule.get("spec", {})
    target = spec.get("target", {})
    manifest = manifest_path(capsule, args.manifest)
    collector = "kubectl-diff"

    if not manifest:
        evidence = inapplicable_manifest_evidence(
            args,
            collector,
            "kubectl diff requires a manifest path; proposed imperative commands are not executed",
        )
        attach_collector_evidence(capsule, "diff", evidence)
        write_capsule_result(capsule, args.file, args.out, args.in_place)
        return 0

    if not Path(manifest).is_file():
        evidence = {
            "ok": False,
            "summary": collector_summary("missing-source", f"manifest file not found: {manifest}"),
            "actor": args.actor,
            "attachedAt": utc_now(),
            "collector": collector,
            "reason": "manifest-not-found",
            **source_fields(manifest),
        }
        attach_collector_evidence(capsule, "diff", evidence)
        write_capsule_result(capsule, args.file, args.out, args.in_place)
        return 0

    command = scoped_kubectl_command([args.kubectl, "diff", "-f", manifest], spec, target)
    result = subprocess.run(command, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, check=False)
    stdout = result.stdout.strip()
    stderr = result.stderr.strip()
    ok = result.returncode in {0, 1}
    if result.returncode == 0:
        reason = "command-ok"
    elif result.returncode == 1:
        reason = "diff-found"
    else:
        reason = "command-failed"
    summary = collector_summary(reason, f"{shell_join(command)} returned {result.returncode}")
    if result.returncode == 1:
        summary += " with diff output"
    elif stdout:
        summary += f" with stdout: {stdout.splitlines()[0]}"

    evidence = {
        "ok": ok,
        "summary": summary,
        "actor": args.actor,
        "attachedAt": utc_now(),
        "collector": collector,
        "reason": reason,
        "command": command,
        "exitCode": result.returncode,
        "stdout": stdout,
        "stderr": stderr,
        "diffFound": result.returncode == 1,
        **source_fields(manifest),
    }
    attach_collector_evidence(capsule, "diff", evidence)
    write_capsule_result(capsule, args.file, args.out, args.in_place)
    return 0


def collect_rollback(args: argparse.Namespace) -> int:
    capsule = load_capsule(args.file)
    spec = capsule.setdefault("spec", {})
    rollback = spec.setdefault("rollback", {"required": True, "provided": False})

    if args.command:
        rollback["provided"] = True
        rollback["command"] = args.command
        evidence = {
            "ok": True,
            "summary": collector_summary("rollback-command", "rollback command attached"),
            "actor": args.actor,
            "attachedAt": utc_now(),
            "collector": "rollback-plan",
            "reason": "rollback-command",
            "rollbackType": "command",
            "command": args.command,
        }
    else:
        if not Path(args.manifest).is_file():
            evidence = {
                "ok": False,
                "summary": collector_summary("missing-source", f"rollback manifest file not found: {args.manifest}"),
                "actor": args.actor,
                "attachedAt": utc_now(),
                "collector": "rollback-plan",
                "reason": "manifest-not-found",
                "rollbackType": "manifest",
                "source": args.manifest,
            }
            attach_collector_evidence(capsule, "rollback", evidence)
            write_capsule_result(capsule, args.file, args.out, args.in_place)
            return 0
        manifest_sha = sha256_file(args.manifest)
        rollback["provided"] = True
        rollback["manifestPath"] = args.manifest
        rollback["manifestSha256"] = manifest_sha
        evidence = {
            "ok": True,
            "summary": collector_summary("rollback-manifest", "rollback manifest attached"),
            "actor": args.actor,
            "attachedAt": utc_now(),
            "collector": "rollback-plan",
            "reason": "rollback-manifest",
            "rollbackType": "manifest",
            "source": args.manifest,
            "sourceSha256": manifest_sha,
        }

    attach_collector_evidence(capsule, "rollback", evidence)
    write_capsule_result(capsule, args.file, args.out, args.in_place)
    return 0


def collect_health_plan(args: argparse.Namespace) -> int:
    capsule = load_capsule(args.file)
    checks = list(capsule.get("spec", {}).get("postChecks", []))
    reason = "health-plan" if checks else "inapplicable"
    evidence = {
        "ok": bool(checks),
        "summary": collector_summary(reason, f"{len(checks)} post-change health check(s) declared"),
        "actor": args.actor,
        "attachedAt": utc_now(),
        "collector": "health-plan",
        "reason": reason,
        "checks": checks,
    }
    if not checks:
        evidence["inapplicable"] = True
    attach_collector_evidence(capsule, "post-checks", evidence)
    write_capsule_result(capsule, args.file, args.out, args.in_place)
    return 0


def digest_capsule(args: argparse.Namespace) -> int:
    capsule = load_capsule(args.file)
    print(f"sha256:{capsule_spec_digest(capsule)}")
    return 0


def render_crd(args: argparse.Namespace) -> int:
    capsule = load_capsule(args.file)
    document = capsule_to_crd(capsule, args)
    write_text("\n".join(yaml_dump(document)), args.out)
    return 0


def gate(args: argparse.Namespace) -> int:
    capsule = load_capsule(args.file)
    missing, failed = evidence_gaps(capsule)
    risk = capsule.get("spec", {}).get("risk", {}).get("level", "unknown")
    command = capsule.get("spec", {}).get("proposedCommand") or capsule.get("spec", {}).get("manifestPath") or "-"
    capsule_id_value = capsule.get("metadata", {}).get("id", "unknown")

    if missing or failed:
        print("gate: closed")
        print(f"id: {capsule_id_value}")
        print(f"risk: {risk}")
        for item in missing:
            print(f"reason: missing evidence {item}")
        for item in failed:
            print(f"reason: failed evidence {item}")
        return 1

    print("gate: open")
    print(f"id: {capsule_id_value}")
    print(f"risk: {risk}")
    print(f"command: {command}")
    return 0


def draft(args: argparse.Namespace) -> int:
    if not args.command and not args.manifest:
        raise SystemExit("draft requires --command or --manifest")
    capsule = make_capsule(args)
    write_json(capsule, args.out)
    return 0


def demo(args: argparse.Namespace) -> int:
    demo_args = argparse.Namespace(
        intent="increase API capacity for checkout traffic",
        command="kubectl scale deployment checkout-api --replicas=6 -n prod",
        manifest=None,
        actor=args.actor,
        context=None,
        namespace=None,
        out="-",
    )
    return draft(demo_args)


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        description="Evidence-carrying operations for AI-assisted Kubernetes.",
        epilog=(
            "Run `kube-actuary help` for workflow help, or "
            "`kube-actuary help agents --format json` for machine-readable guidance."
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("--version", action="version", version=f"kube-actuary {VERSION}")
    sub = parser.add_subparsers(dest="command_name", required=True)

    draft_parser = sub.add_parser("draft", help="create an operation capsule draft")
    draft_parser.add_argument("--intent", required=True)
    draft_parser.add_argument("--command")
    draft_parser.add_argument("--manifest")
    draft_parser.add_argument("--actor", default=os.environ.get("USER") or getpass.getuser())
    draft_parser.add_argument("--context")
    draft_parser.add_argument("--namespace")
    draft_parser.add_argument("--out", default="-")
    draft_parser.set_defaults(func=draft)

    inspect_parser = sub.add_parser("inspect", help="print a capsule summary")
    inspect_parser.add_argument("file")
    inspect_parser.set_defaults(func=inspect_capsule)

    validate_parser = sub.add_parser("validate", help="validate capsule JSON structure")
    validate_parser.add_argument("file")
    validate_parser.add_argument("--format", choices=["text", "json"], default="text")
    validate_parser.set_defaults(func=validate_capsule)

    doctor_parser = sub.add_parser("doctor", help="check local runtime and kubectl client diagnostics")
    doctor_parser.add_argument("--kubectl", default="kubectl")
    doctor_parser.add_argument("--server-version", help="optional Kubernetes server version for minor-skew hints")
    doctor_parser.add_argument("--format", choices=["text", "json"], default="text")
    doctor_parser.set_defaults(func=doctor)

    verify_parser = sub.add_parser("verify", help="check that required evidence is attached")
    verify_parser.add_argument("file")
    verify_parser.set_defaults(func=verify_capsule)

    attach_parser = sub.add_parser("attach-evidence", help="attach evidence to a capsule")
    attach_parser.add_argument("file")
    attach_parser.add_argument("--id", required=True)
    attach_parser.add_argument("--summary", required=True)
    attach_parser.add_argument("--source")
    attach_parser.add_argument("--actor", default=os.environ.get("USER") or getpass.getuser())
    attach_parser.add_argument("--fail", action="store_true", help="mark this evidence as failed")
    attach_parser.add_argument("--allow-extra", action="store_true")
    attach_parser.add_argument("--in-place", action="store_true")
    attach_parser.add_argument("--out", default="-")
    attach_parser.set_defaults(func=attach_evidence)

    collect_parser = sub.add_parser("collect", help="collect safe evidence for a capsule")
    collect_sub = collect_parser.add_subparsers(dest="collector_name", required=True)

    auth_parser = collect_sub.add_parser("auth", help="attach kubectl auth can-i evidence")
    auth_parser.add_argument("file")
    auth_parser.add_argument("--kubectl", default="kubectl")
    auth_parser.add_argument("--actor", default=os.environ.get("USER") or getpass.getuser())
    auth_parser.add_argument("--in-place", action="store_true")
    auth_parser.add_argument("--out", default="-")
    auth_parser.set_defaults(func=collect_auth)

    dry_run_parser = collect_sub.add_parser("dry-run", help="attach server-side dry-run evidence")
    dry_run_parser.add_argument("file")
    dry_run_parser.add_argument("--manifest")
    dry_run_parser.add_argument("--kubectl", default="kubectl")
    dry_run_parser.add_argument("--actor", default=os.environ.get("USER") or getpass.getuser())
    dry_run_parser.add_argument("--in-place", action="store_true")
    dry_run_parser.add_argument("--out", default="-")
    dry_run_parser.set_defaults(func=collect_dry_run)

    diff_parser = collect_sub.add_parser("diff", help="attach kubectl diff evidence")
    diff_parser.add_argument("file")
    diff_parser.add_argument("--manifest")
    diff_parser.add_argument("--kubectl", default="kubectl")
    diff_parser.add_argument("--actor", default=os.environ.get("USER") or getpass.getuser())
    diff_parser.add_argument("--in-place", action="store_true")
    diff_parser.add_argument("--out", default="-")
    diff_parser.set_defaults(func=collect_diff)

    rollback_parser = collect_sub.add_parser("rollback", help="attach rollback command or manifest evidence")
    rollback_parser.add_argument("file")
    rollback_source = rollback_parser.add_mutually_exclusive_group(required=True)
    rollback_source.add_argument("--command")
    rollback_source.add_argument("--manifest")
    rollback_parser.add_argument("--actor", default=os.environ.get("USER") or getpass.getuser())
    rollback_parser.add_argument("--in-place", action="store_true")
    rollback_parser.add_argument("--out", default="-")
    rollback_parser.set_defaults(func=collect_rollback)

    health_plan_parser = collect_sub.add_parser("health-plan", help="attach post-change health plan evidence")
    health_plan_parser.add_argument("file")
    health_plan_parser.add_argument("--actor", default=os.environ.get("USER") or getpass.getuser())
    health_plan_parser.add_argument("--in-place", action="store_true")
    health_plan_parser.add_argument("--out", default="-")
    health_plan_parser.set_defaults(func=collect_health_plan)

    render_parser = sub.add_parser("render-crd", help="render a capsule as an OperationCapsule CRD object")
    render_parser.add_argument("file")
    render_parser.add_argument("--name")
    render_parser.add_argument("--namespace")
    render_parser.add_argument("--actor-type", default="ai-agent", choices=["human", "ai-agent", "ci", "controller"])
    render_parser.add_argument("--rollback-command")
    render_parser.add_argument("--ttl-seconds-after-finished", type=int)
    render_parser.add_argument("--out", default="-")
    render_parser.set_defaults(func=render_crd)

    gate_parser = sub.add_parser("gate", help="open only when all required evidence has passed")
    gate_parser.add_argument("file")
    gate_parser.set_defaults(func=gate)

    demo_parser = sub.add_parser("demo", help="print a sample high-risk capsule")
    demo_parser.add_argument("--actor", default="ai-agent")
    demo_parser.set_defaults(func=demo)

    digest_parser = sub.add_parser("digest", help="print deterministic capsule spec digest")
    digest_parser.add_argument("file")
    digest_parser.set_defaults(func=digest_capsule)

    help_parser = sub.add_parser(
        "help",
        help="show workflow, safety, evidence, or agent guidance",
        description="Show KubeActuary help in a human-readable or agent-readable form.",
    )
    help_parser.add_argument("topic", nargs="?", default="overview", choices=HELP_TOPICS)
    help_parser.add_argument("--format", choices=["text", "json"], default="text")
    help_parser.set_defaults(func=help_command)

    return parser


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())
